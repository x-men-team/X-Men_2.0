# X-Men Application Configuration Template
# Copy this file to .env and update the values as needed

# Server Configuration
SERVER_PORT=8081

# API Configuration
API_BASE_URL=http://localhost:8081
API_GENERATE_MUTATIONS_ENDPOINT=/api/generateMutations
API_FULL_URL=http://localhost:8081/api/generateMutations

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:808[2-9],http://localhost:80[9-9][0-9]
CORS_MAX_AGE=3600

# Application Settings
APP_NAME=X-Men
