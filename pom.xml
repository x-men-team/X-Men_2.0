        <!--
          Linux .deb / .rpm extras: menu category + .desktop integration so the
          package shows up under Applications -> Development with the X-Men
          icon, AND so it appears in the OS uninstaller (GNOME Software /
          KDE Discover / elementary AppCenter).

          The resourceDir override ships custom Debian postinst + prerm scripts
          that write an AppStream metainfo XML into /usr/share/metainfo/. Modern
          Ubuntu (22.04+) and similar distros only list installed apps in their
          graphical control plane when AppStream metadata is present — without
          this the user has to drop to a terminal (`sudo apt remove x-men`)
          to uninstall, which is the symptom we are fixing.

          linuxAppRelease pins the Debian release suffix so the resulting file
          is reproducibly named x-men_1.0.0-1_amd64.deb and dpkg can compute
          proper upgrade ordering across versions.
        -->
        <profile>
            <id>installer-linux-extras</id>
            <activation>
                <os>
                    <family>unix</family>
                    <name>linux</name>
                </os>
                <property>
                    <name>jpackage.type</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.panteleyev</groupId>
                        <artifactId>jpackage-maven-plugin</artifactId>
                        <version>1.6.5</version>
                        <executions>
                            <execution>
                                <id>build-installer</id>
                                <configuration>
                                    <linuxShortcut>true</linuxShortcut>
                                    <linuxMenuGroup>Development;Security;Utility;</linuxMenuGroup>
                                    <linuxPackageName>x-men</linuxPackageName>
                                    <linuxAppCategory>Development</linuxAppCategory>
                                    <!--
                                      Match the Linux profile's JavaFX runtime: 27-ea+18
                                      ships libavplugin-ffmpeg-56..62, so include the
                                      62 SONAMEs (Ubuntu 26.04 "Resolute", Debian
                                      Trixie+) alongside the 58-61 set that older LTS
                                      releases (Ubuntu 24.04, Debian 12) still ship.
                                      apt picks the first installable alternative, and
                                      JavaFX has a matching plugin for whichever wins.
                                    -->
