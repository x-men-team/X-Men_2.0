        <!--
          Installer profile: turns the Spring Boot fat jar into a native installer
          via the JDK's `jpackage` tool.

          Usage:
            mvn clean package -P installer                          # default: app-image (folder, no installer tool needed)
            mvn clean package -P installer -Djpackage.type=EXE      # Windows .exe (requires WiX Toolset 3.x on PATH)
            mvn clean package -P installer -Djpackage.type=MSI      # Windows .msi (requires WiX Toolset 3.x on PATH)
            mvn clean package -P installer -Djpackage.type=DMG      # macOS  .dmg
            mvn clean package -P installer -Djpackage.type=PKG      # macOS  .pkg
            mvn clean package -P installer -Djpackage.type=DEB      # Linux  .deb
            mvn clean package -P installer -Djpackage.type=RPM      # Linux  .rpm

          The per-OS icon (-Djpackage.icon=…) is picked automatically by the
          activate-by-OS profiles below, so callers don't need to set it.

          Override the user-visible version with -Djpackage.appVersion=X.Y.Z
          (jpackage rejects Maven SNAPSHOT versions).
        -->
        <profile>
            <id>installer</id>

            <properties>
                <jpackage.type>APP_IMAGE</jpackage.type>
                <jpackage.appVersion>1.0.0</jpackage.appVersion>
                <!--
                  Fallback icon if no OS-specific profile fired. Each platform
                  profile below overrides this to point at the native format
                  (.ico on Windows, .icns on macOS, .png on Linux).
                -->
                <jpackage.icon>${project.basedir}/src/main/resources/packaging/x-men-icon.png</jpackage.icon>
            </properties>

            <build>
                <plugins>
                    <!-- 1) Stage the Spring Boot fat jar into a clean input folder. -->
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-resources-plugin</artifactId>
                        <executions>
                            <execution>
                                <id>stage-jpackage-input</id>
                                <phase>package</phase>
                                <goals>
                                    <goal>copy-resources</goal>
                                </goals>
                                <configuration>
                                    <outputDirectory>${project.build.directory}/jpackage-input</outputDirectory>
                                    <resources>
                                        <resource>
                                            <directory>${project.build.directory}</directory>
                                            <includes>
                                                <include>${project.build.finalName}.jar</include>
                                            </includes>
                                        </resource>
                                    </resources>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>

                    <!-- 2) Invoke jpackage. -->
                    <plugin>
                        <groupId>org.panteleyev</groupId>
                        <artifactId>jpackage-maven-plugin</artifactId>
                        <version>1.6.5</version>
                        <executions>
                            <execution>
                                <id>build-installer</id>
                                <phase>package</phase>
                                <goals>
                                    <goal>jpackage</goal>
                                </goals>
                                <configuration>
                                    <name>X-Men</name>
                                    <appVersion>${jpackage.appVersion}</appVersion>
                                    <vendor>X-Men</vendor>
                                    <input>${project.build.directory}/jpackage-input</input>
                                    <destination>${project.build.directory}/dist</destination>
                                    <mainJar>${project.build.finalName}.jar</mainJar>
                                    <mainClass>org.springframework.boot.loader.launch.JarLauncher</mainClass>
                                    <type>${jpackage.type}</type>
                                    <icon>${jpackage.icon}</icon>
                                    <javaOptions>
                                        <option>-Djava.awt.headless=false</option>
                                        <option>-Dfile.encoding=UTF-8</option>
                                        <!--
                                          Bundled JRE heap budget. Forget +
                                          derivation on Bank/Oyster occasionally
                                          peaks at a few hundred MB of
                                          intermediate model state, but the
                                          previous 2 GB cap was big enough to
                                          push a low-RAM Intel Mac (8 GB shared
                                          with the iGPU) into swap on launch and
                                          freeze the WindowServer. 1 GB is
                                          comfortably above the working set we
                                          measured on the Bank case study and
                                          leaves the OS room to breathe.
                                        -->
                                        <option>-Xmx1g</option>
                                        <option>-XX:MaxMetaspaceSize=256m</option>
                                    </javaOptions>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!--
          OS-specific icon override + jpackage extras. Each profile activates
          automatically when running on the matching family, so callers can use
          a single command (e.g. `mvn package -P installer -Djpackage.type=DMG`)
